<Window x:Class="CADDedupPlugin.MaterialSyncDiffPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PLM 物料字段差异确认"
        Height="560"
        Width="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Width" Value="96"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#757575"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="PLM 物料字段差异确认" FontSize="20" FontWeight="Bold" Foreground="#1976D2"/>
                    <TextBlock x:Name="txtContext" Text="Profile / Item"
                               FontSize="12" Foreground="#666666" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="txtSummary" Text="待写回 0 项"
                               FontSize="14" FontWeight="SemiBold" Foreground="#333333"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                <TextBlock x:Name="txtWarning"
                           Text="请确认差异后再写回当前 DWG。只有 added / changed / cleared 字段会被写回。"
                           TextWrapping="Wrap"
                           Foreground="#555555"/>
            </Border>

            <DataGrid Grid.Row="1"
                      x:Name="gridDiffs"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      BorderThickness="1"
                      BorderBrush="#E0E0E0"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="CAD 字段" Binding="{Binding CadKey}" Width="140"/>
                    <DataGridTextColumn Header="属性" Binding="{Binding Property}" Width="130"/>
                    <DataGridTextColumn Header="当前值" Binding="{Binding CurrentText}" Width="*"/>
                    <DataGridTextColumn Header="目标值" Binding="{Binding TargetText}" Width="*"/>
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Row="2" Background="White" Padding="0,12,0,0" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="确认后将只写回待写字段包，不会写回 unchanged 字段。"
                           VerticalAlignment="Center"
                           Foreground="#666666"/>

                <Button x:Name="btnConfirm"
                        Grid.Column="1"
                        Content="确认写回"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnConfirm_Click"/>

                <Button x:Name="btnCancel"
                        Grid.Column="2"
                        Content="取消"
                        Style="{StaticResource SecondaryButton}"
                        Click="BtnCancel_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
