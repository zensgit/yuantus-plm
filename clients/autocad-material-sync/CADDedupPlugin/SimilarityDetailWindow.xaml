<Window x:Class="CADDedupPlugin.SimilarityDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="图纸相似度详细分析" Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- 卡片样式 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 标题样式 -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- 进度条样式 -->
        <Style x:Key="SimilarityBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="Foreground" Value="#4CAF50"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="图纸相似度分析报告" FontSize="20" FontWeight="Bold" Foreground="#1976D2"/>
                    <TextBlock x:Name="txtTimestamp" Text="分析时间：2025-01-01 12:00:00"
                               FontSize="12" Foreground="#757575" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="总体相似度：" FontSize="14" Foreground="#666666" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtOverallSimilarity" Text="0.0%" FontSize="24" FontWeight="Bold"
                               Foreground="#1976D2" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区（滚动） -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,12">
            <StackPanel>
                <!-- 相似度分解 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="📊 相似度分解" Style="{StaticResource SectionTitle}"/>

                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <!-- 形状相似度 -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="形状相似度" VerticalAlignment="Center" Foreground="#666666"/>
                            <ProgressBar x:Name="barShapeSimilarity" Grid.Row="0" Grid.Column="1" Style="{StaticResource SimilarityBar}"
                                         Maximum="1.0" Value="0.0"/>
                            <TextBlock x:Name="txtShapeSimilarity" Grid.Row="0" Grid.Column="2" Text="0.0%"
                                       FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                            <!-- 特征相似度 -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="特征相似度" VerticalAlignment="Center" Foreground="#666666"/>
                            <ProgressBar x:Name="barFeatureSimilarity" Grid.Row="1" Grid.Column="1" Style="{StaticResource SimilarityBar}"
                                         Maximum="1.0" Value="0.0"/>
                            <TextBlock x:Name="txtFeatureSimilarity" Grid.Row="1" Grid.Column="2" Text="0.0%"
                                       FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                            <!-- 尺寸相似度 -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="尺寸相似度" VerticalAlignment="Center" Foreground="#666666"/>
                            <ProgressBar x:Name="barDimensionSimilarity" Grid.Row="2" Grid.Column="1" Style="{StaticResource SimilarityBar}"
                                         Maximum="1.0" Value="0.0"/>
                            <TextBlock x:Name="txtDimensionSimilarity" Grid.Row="2" Grid.Column="2" Text="0.0%"
                                       FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 相似原因 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="✅ 相似原因" Style="{StaticResource SectionTitle}"/>
                        <ItemsControl x:Name="listReasons">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                        <Ellipse Width="6" Height="6" Fill="#4CAF50" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#333333"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- 关键差异 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="⚠️ 关键差异" Style="{StaticResource SectionTitle}"/>
                        <ItemsControl x:Name="listDifferences">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                        <Ellipse Width="6" Height="6" Fill="#FF9800" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#333333"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- 特征对比 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="🔍 特征对比" Style="{StaticResource SectionTitle}"/>
                        <DataGrid x:Name="gridFeatureComparison"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F9F9F9"
                                  BorderThickness="1"
                                  BorderBrush="#E0E0E0"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="特征类型" Binding="{Binding FeatureType}" Width="120"/>
                                <DataGridTextColumn Header="原图数量" Binding="{Binding OriginalCount}" Width="100"/>
                                <DataGridTextColumn Header="新图数量" Binding="{Binding NewCount}" Width="100"/>
                                <DataGridTextColumn Header="匹配状态" Binding="{Binding MatchStatus}" Width="120"/>
                                <DataGridTextColumn Header="详细说明" Binding="{Binding Details}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- 综合评估 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="📝 综合评估" Style="{StaticResource SectionTitle}"/>
                        <TextBlock x:Name="txtSummary"
                                   TextWrapping="Wrap"
                                   Foreground="#333333"
                                   LineHeight="24"
                                   Text="正在加载分析结果..."/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮栏 -->
        <Border Grid.Row="2" Background="White" Padding="0,12,0,0" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnExport"
                        Grid.Column="1"
                        Content="导出报告"
                        Width="100"
                        Height="36"
                        Margin="0,0,12,0"
                        Background="#2196F3"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnExport_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1976D2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="btnClose"
                        Grid.Column="2"
                        Content="关闭"
                        Width="100"
                        Height="36"
                        Background="#757575"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#616161"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
