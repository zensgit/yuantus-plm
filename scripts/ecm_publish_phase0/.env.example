# Phase 0 smoke config — copy to .env, fill, then:  set -a; source .env; set +a

# --- Keycloak (Athena's IdP): a client-credentials service account for the PLM ---
# Create a confidential client with "Service accounts roles" enabled, then try a
# realm role until Athena accepts CMIS writes (record which one — that is U1).
KC_TOKEN_URL=http://localhost:8080/realms/ecm/protocol/openid-connect/token
KC_CLIENT_ID=plm-ecm-publisher
KC_CLIENT_SECRET=change-me

# --- Athena CMIS Browser binding base URL ---
ATHENA_BROWSER=http://localhost:7700/api/cmis/browser

# --- Tenant + a pre-existing folder node id UNDER that tenant's root ---
# This is the "base" folder; the script creates Released/<part> under it.
ATHENA_TENANT=tenant-1
ATHENA_FOLDER_ID=REPLACE_WITH_A_FOLDER_NODE_ID_UNDER_tenant-1_ROOT

# --- Optional ---
PART_NUMBER=P-PHASE0-0001
