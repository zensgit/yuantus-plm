# One-time bootstrap values for a shared-dev Yuantus deployment.
# Copy to a local env file and feed it to docker compose:
#
#   docker compose --env-file ./deployments/docker/shared-dev.bootstrap.env \
#     --profile bootstrap run --rm bootstrap
#
# Do not commit real passwords.

YUANTUS_BOOTSTRAP_TENANT_ID=tenant-1
YUANTUS_BOOTSTRAP_ORG_ID=org-1

YUANTUS_BOOTSTRAP_ADMIN_USERNAME=admin
YUANTUS_BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
YUANTUS_BOOTSTRAP_ADMIN_USER_ID=1
YUANTUS_BOOTSTRAP_ADMIN_ROLES=admin

YUANTUS_BOOTSTRAP_VIEWER_USERNAME=ops-viewer
YUANTUS_BOOTSTRAP_VIEWER_PASSWORD=change-me-viewer-password
YUANTUS_BOOTSTRAP_VIEWER_USER_ID=2
YUANTUS_BOOTSTRAP_VIEWER_ROLES=ops-viewer

YUANTUS_BOOTSTRAP_SKIP_META=0
YUANTUS_BOOTSTRAP_DATASET_MODE=p2-observation
YUANTUS_BOOTSTRAP_FIXTURE_MANIFEST_PATH=./tmp/p2_observation_fixture_manifest.json
