{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CAD Connector Convert Response",
  "type": "object",
  "required": ["ok"],
  "properties": {
    "ok": { "type": "boolean" },
    "job_id": { "type": ["string", "null"] },
    "artifacts": {
      "type": "object",
      "properties": {
        "geometry": {
          "type": "object",
          "properties": {
            "gltf_url": { "type": "string" },
            "glb_url": { "type": "string" },
            "obj_url": { "type": "string" },
            "bin_url": { "type": "string" },
            "lods": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "level": { "type": ["integer", "string"] },
                  "ratio": { "type": "number" },
                  "gltf_url": { "type": "string" },
                  "glb_url": { "type": "string" },
                  "obj_url": { "type": "string" },
                  "bin_url": { "type": "string" }
                },
                "additionalProperties": true
              }
            },
            "bbox": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 6,
              "maxItems": 6
            }
          },
          "additionalProperties": true
        },
        "preview": {
          "type": "object",
          "properties": {
            "png_url": { "type": "string" },
            "jpg_url": { "type": "string" },
            "jpeg_url": { "type": "string" }
          },
          "additionalProperties": true
        },
        "result": {
          "type": "object",
          "properties": {
            "status": { "type": "string" },
            "error_output": { "type": ["string", "null"] },
            "warnings": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        },
        "mesh_stats": {
          "type": "object",
          "properties": {
            "triangle_count": { "type": ["integer", "null"] },
            "entity_count": { "type": ["integer", "null"] }
          },
          "additionalProperties": true
        },
        "attributes": { "type": "object" },
        "bom": { "type": "object" }
      },
      "additionalProperties": true
    },
    "error": { "type": ["string", "null"] },
    "code": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
